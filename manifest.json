{
  "manifest_version": 3,
  "name": "Summary Tool",
  "version": "0.2.0",
  "description": "Grab YouTube transcripts — search, copy, download as TXT/SRT. Or summarise any web page with your own AI key.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.notion.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html?panel=1"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      }
    }
  }
}
